# Copy this file to .env before first startup and change the password.

CONFLUENCE_VERSION=latest
CONFLUENCE_PLATFORM=linux/amd64
CONFLUENCE_HTTP_PORT=8090

POSTGRES_VERSION=16-alpine
POSTGRES_DB=confluence
POSTGRES_USER=confluence
POSTGRES_PASSWORD=change-me

JVM_MINIMUM_MEMORY=2048m
JVM_MAXIMUM_MEMORY=4096m
JVM_SUPPORT_RECOMMENDED_ARGS=-Dsynchrony.proxy.enabled=false -Dsynchrony.btf.off=true
ATL_TOMCAT_SCHEME=http
